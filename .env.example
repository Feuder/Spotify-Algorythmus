# Kopiere diese Datei bei Bedarf als .env. Die Root-.env ist die einzige
# Konfigurationsdatei fuer Backend, Worker, Datenbank und Frontend.

APP_NAME=Resonanz
APP_ENV=development
APP_TIMEZONE=Europe/Berlin
APP_LOG_LEVEL=INFO
# Erzeugen: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

POSTGRES_DB=resonanz
POSTGRES_USER=resonanz
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://resonanz:PASSWORT@postgres:5432/resonanz

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/auth/spotify/callback

LASTFM_API_KEY=
GETSONGBPM_API_KEY=
MUSICBRAINZ_CONTACT_EMAIL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

AUTOMATION_ENABLED=true
AUTOMATION_DAILY_TIME=06:00
DEFAULT_PLAYLIST_DURATION_MINUTES=300
DEFAULT_DISCOVERY_PERCENT=20
CURRENT_PLAYBACK_POLL_SECONDS=30

DEMO_MODE=true
ALLOW_QUEUE_ASSISTANT=false
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

